# ---- OS ----
.DS_Store
Thumbs.db

# ---- Editors / IDEs ----
# .idea/ project files are intentionally tracked; user-specific files are
# handled by .idea/.gitignore. Ignore common editor scratch files here.
*.swp
*.swo
*~
.vscode/

# ---- Environment / secrets ----
.env
.env.*
!.env*.example

# ---- Logs ----
*.log

# ---- Backend (Go + air) ----
backend/tmp/
backend/build-errors.log
*.test
*.out
coverage.*
# Go workspace: only used for local WSCA builds (-tags wsca) that pull in the
# private wallet-provider clone; paths are per-developer. See .ai/features/wsca-holder-binding.md.
go.work
go.work.sum

# ---- Node (root tooling: husky, lint-staged) ----
node_modules/

# ---- PostGuard sidecar (Node / tsc) ----
postguard-sidecar/dist/

# ---- Frontend (Node / Vite) ----
frontend/node_modules/
frontend/dist/
frontend/.vite/
frontend/.eslintcache
*.tsbuildinfo
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ---- AI / Claude ----
.claude/worktrees/
.ai/plans/*
!.ai/plans/README.md

Yivi Design System/
