# Postgres credentials used by Docker Compose (the `db` service and backend).
POSTGRES_USER=postgres
# REQUIRED: Compose refuses to start without this. Set a strong, unique value.
# Do NOT deploy with the placeholder below — CHANGE_ME is not a valid password.
POSTGRES_PASSWORD=CHANGE_ME
POSTGRES_DB=yivi_business_wallet

# OpenID4VP disclosure runs against a hosted EUDI verifier; the default is the
# Yivi staging verifier. Override to point at your own deployment:
# EUDI_VERIFIER_URL=https://verifierapi.openid4vc.staging.yivi.app

# Comma-separated emails granted platform-admin
# PLATFORM_ADMIN_EMAILS=you@example.com

# PostGuard (encrypted file transfer). BOTH are REQUIRED — Compose refuses to
# start without them (the sidecar fails closed, the backend needs the key to
# store API keys at rest).
#
# Shared secret between the backend and the PostGuard sidecar. Generate with:
#   openssl rand -hex 32
POSTGUARD_SHARED_SECRET=CHANGE_ME
# Deployment master key: a hex-encoded 32-byte value that WRAPS each org's own
# (owner-configured) PostGuard encryption key at rest. The per-org key in turn
# encrypts that org's API key. REQUIRED — generate a unique value with:
#   openssl rand -hex 32
# Do NOT deploy with the placeholder below (it is not valid hex, so the backend
# refuses to start). Rotating this makes all previously stored per-org keys
# (and thus API keys) undecryptable.
POSTGUARD_KEY_ENCRYPTION_KEY=CHANGE_ME
# Optional: PostGuard for Business backend. Defaults to production; override for
# staging (https://pkg.staging.postguard.eu / https://storage.staging.postguard.eu).
# POSTGUARD_PKG_URL=https://pkg.postguard.eu
# POSTGUARD_CRYPTIFY_URL=https://storage.postguard.eu
# Public PostGuard website the recipient download link points at, used only when an
# org chooses "own SMTP server" for PostGuard notifications (the backend then mails
# recipients a <website>/download?uuid=... link itself). Defaults to production;
# override for staging (https://staging.postguard.eu).
# POSTGUARD_WEBSITE_URL=https://postguard.eu

# Deployment key that seals each org's WSCA activation secret at rest (AES-256-GCM,
# hex-encoded 32 bytes; source from a KMS/secret manager). REQUIRED once WSCA-backed
# holder binding is enabled (the ATTESTATION_HOLDER_WSCA_URL toggle below).
# Generate with: openssl rand -hex 32. See .ai/features/wsca-holder-binding.md.
# ATTESTATION_HOLDER_WSCA_KEK=CHANGE_ME
#
# WSCA-backed holder binding (holder keys live in the wallet-provider HSM under
# SECDSA sole control instead of software keys). Opt-in: set the wallet-provider
# URL to enable it (requires ATTESTATION_HOLDER=irmago and the KEK above).
#
# For LOCAL Docker testing, do NOT set these here — layer compose.wsca.yaml
# instead (it builds the backend with -tags wsca against a wallet-provider clone
# and defaults the URL to Yivi staging). You only need ATTESTATION_HOLDER_WSCA_KEK
# set. See .ai/features/wsca-holder-binding.md.
# ATTESTATION_HOLDER_WSCA_URL=https://wallet-provider.staging.yivi.app
# Parent dir for per-org walletmobile keystores (a persistent volume in prod).
# ATTESTATION_HOLDER_WSCA_KEYSTORE_DIR=/var/lib/ybw/wsca
# Trust the wallet-provider's dev/self-signed TLS cert (local/staging only).
# ATTESTATION_HOLDER_WSCA_INSECURE=false
