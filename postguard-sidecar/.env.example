# PostGuard sidecar configuration (see src/config.ts).

# Shared secret the Go backend must present as `Authorization: Bearer <token>`.
# REQUIRED — the sidecar refuses to start without it. Must match the backend's
# POSTGUARD_SHARED_SECRET.
PG_SIDECAR_TOKEN=

# Listen address. The port is never published to the host in Compose; the
# backend reaches the sidecar by its service name over the private network.
PG_SIDECAR_PORT=8090
PG_SIDECAR_BIND=0.0.0.0

# PostGuard for Business backend endpoints (default to production). Point at
# https://pkg.staging.postguard.eu / https://storage.staging.postguard.eu for
# the staging environment.
PG_PKG_URL=https://pkg.postguard.eu
PG_CRYPTIFY_URL=https://storage.postguard.eu

# Maximum per-request upload size in bytes (default 100 MB).
PG_MAX_UPLOAD_BYTES=104857600
