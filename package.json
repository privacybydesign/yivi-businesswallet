{
  "name": "yivi-business-wallet",
  "private": true,
  "scripts": {
    "prepare": "husky",
    "dev": "tsx dev-setup",
    "dev:debug": "tsx dev-setup --debug",
    "dev:reset": "tsx dev-setup --reset"
  },
  "devDependencies": {
    "@types/node": "^26.0.0",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.7",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3"
  },
  "lint-staged": {
    "backend/**/*.go": [
      "go run golang.org/x/tools/cmd/goimports@v0.45.0 -w -local github.com/privacybydesign/yivi-businesswallet/backend",
      "go run mvdan.cc/gofumpt@v0.9.2 -w"
    ]
  }
}
